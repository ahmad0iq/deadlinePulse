{
    "manifest_version": 3,
    "name": "DeadlinePulse",
    "description": "Auto-tracks pending submissions from Horizon portal and shows them in a sleek floating panel.",
    "version": "1.0",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "scripting",
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "*://horizon.ucp.edu.pk/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://horizon.ucp.edu.pk/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "inject.css"
            ]
        }
    ]
}